# .env.example — copy thành .env và điền giá trị thật (không commit .env lên Git)

# PostgreSQL (đang chạy native trên Windows)
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# JWT
JWT_SECRET=change-this-to-a-long-random-string

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL_NAME=models/gemini-2.5-flash
GEMINI_MODEL_RAG=gemini-2.5-flash

# CORS — thêm domain thật sau khi setup Cloudflare
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Cloudflare Tunnel token (lấy từ Cloudflare Dashboard)
TUNNEL_TOKEN=

# Docker Hub username (để Watchtower biết image nào cần watch)
DOCKERHUB_USERNAME=your_dockerhub_username

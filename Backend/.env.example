# ── Database (PostgreSQL — external/shared) ──────────────────────────────────
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=change-me

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=production

# ── CORS: domain frontend được phép gọi API (phân tách bằng dấu phẩy) ────────
# Thêm domain Vercel khi deploy, vd:
# CORS_ORIGINS=https://emapp.vercel.app,https://emapp.xyz
CORS_ORIGINS=http://localhost:3000

# ── Google / Gemini ──────────────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_API_KEY_1=
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash
GEMINI_MODEL_RAG=gemini-2.0-flash

# ── Voice / Chatbot TTS ──────────────────────────────────────────────────────
VOICE_STT_DEV_MOCK=false
VOICE_DIALOG_TTS=false
CHATBOT_TTS=false

# ── Misc ─────────────────────────────────────────────────────────────────────
PROCEDURE_LINK_BASE=
APPOINTMENT_SLOTS=
APPOINTMENT_MAX_PER_SLOT=

# ── Cloudflare tunnel (dùng bởi service cloudflared trong docker-compose) ─────
TUNNEL_TOKEN=

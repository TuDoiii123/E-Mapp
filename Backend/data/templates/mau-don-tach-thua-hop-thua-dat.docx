" href="styles.dfa954bc54f3768a.css"></noscript></head>

<body>
    <!-- Loading Screen -->
    <core-loading-screen id="loading-bg">
        <!--<div class="loading-logo"><img src="/assets/images/hand-shake.png" style="width: 130px; height: 130px;"
                alt="Logo" /></div>
        <div class="loading">
            <div class="effect-1 effects"></div>
            <div class="effect-2 effects"></div>
            <div class="effect-3 effects"></div>
        </div>-->
        <div class="loading-overlay">
            <div class="loading-spinner"></div>
        </div>
    </core-loading-screen>
    <!-- / Loading Screen -->
    <!-- Root component -->
    <app-root></app-root>
    <!-- / Root component -->
    <iframe id="hidden-logout-iframe" style="display:none"></iframe>
    <!-- Begin EMC Tracking Code --------------------------------------------------- HA NOI -->
    <script type="text/javascript">
        var _govaq = window._govaq || [];
        _govaq.push(['trackPageView']);
        _govaq.push(['enableLinkTracking']);

        // Load config and initialize tracking
        fetch('/assets/config.json')
            .then(response => response.json())
            .then(config => {
                // Update page title with cityName from config
                if (config.city_name) {
                    document.getElementById('page-title').textContent =
                        `HỆ THỐNG THÔNG TIN GIẢI QUYẾT THỦ TỤC HÀNH CHÍNH ${config.city_name}`;
                }

                _govaq.push(['setTrackerUrl', 'https://f-emc.ngsp.gov.vn/tracking']);
                _govaq.push(['setSiteId', config.site_id ]);
                console.log('setSiteId:', config.site_id);
                var d = document,
                    g = d.createElement('script'),
                    s = d.getElementsByTagName('script')[0];
                g.type = 'text/javascript';
                g.async = true;
                g.defer = true;
                g.src = 'https://f-emc.ngsp.gov.vn/embed/gov-tracking.min.js';
                s.parentNode.insertBefore(g, s);
            })
            .catch(error => {
                console.error('Error loading config:', error);
            });
    </script>
    <!-- End EMC Tracking Code -->
<script src="runtime.73b377aa68ed5e7c.js" type="module"></script><script src="polyfills.eb670871d277d602.js" type="module"></script><script src="scripts.d75b76de1e888f7d.js" defer></script><script src="main.0caca5cea1ba1ced.js" type="module"></script>

</body></html>
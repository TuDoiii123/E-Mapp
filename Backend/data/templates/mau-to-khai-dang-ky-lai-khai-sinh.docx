$('.table-news-home .nav-tabs a').click(function(){
if(!$(this).hasClass('has-click')){
$(this).addClass('has-click');
var content = $(this).attr('href');
var id = $(content).find('div[id^="module"]').attr('id').slice(6);
if(id){
console.log($('#module'+id).find('.bx-viewport'));
$('#module'+id).find('.bx-viewport').css('height','');
setTimeout(function(){
$('#module'+id).find('.bx-viewport').css('height','');
$('#bxSlider'+id).bxSlider({
pager:false,
controls:false,
}).reloadSlider();
},200);
}
}
});
 
  
  
  
  
  
  
  
